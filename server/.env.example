# ===============================================
# 菜菜星球 - 环境变量配置示例
# ===============================================
# 请复制此文件为 .env 并填写实际值
# ===============================================

# ===============================================
# 基础配置
# ===============================================
NODE_ENV=development

# 服务器端口（可选，默认3002）
PORT=3002

# 前端URL（可选，用于CORS配置）
CLIENT_URL=http://localhost:3000

# ===============================================
# 数据库配置 - 本地开发
# ===============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=123456
DB_NAME=caicaitask520

# ===============================================
# 数据库配置 - 生产环境（云端MySQL）
# ===============================================
# DB_HOST=your_cloud_db_host
# DB_PORT=3306
# DB_USER=your_cloud_db_user
# DB_PASSWORD=your_cloud_db_password
# DB_NAME=your_cloud_db_name

# ===============================================
# 七牛云配置 - 生产环境
# ===============================================
# QINIU_ACCESS_KEY=your_qiniu_access_key
# QINIU_SECRET_KEY=your_qiniu_secret_key
# QINIU_BUCKET=caicaimars520
# QINIU_DOMAIN=https://img.caicaistack.click

# ===============================================
# 邮件配置
# ===============================================
# 163邮箱配置
EMAIL_163_USER=caicaifensi520@163.com
EMAIL_163_AUTH_CODE=your_auth_code

# QQ邮箱配置
EMAIL_QQ_USER=caicaijiejie520@qq.com
EMAIL_QQ_AUTH_CODE=your_qq_auth_code

# ===============================================
# JWT配置
# ===============================================
JWT_SECRET=your_jwt_secret_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ===============================================
# 本地存储配置（仅开发环境使用）
# ===============================================
UPLOAD_PATH=../uploads
MAX_FILE_SIZE=5242880
LOCAL_BASE_URL=http://localhost:3002
