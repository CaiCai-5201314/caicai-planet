# 数据库配置
DB_NAME=your_database_name
DB_HOST=your_database_host
DB_PORT=3306
DB_USER=your_database_user
DB_PASSWORD=your_strong_database_password

# JWT配置
JWT_SECRET=your_strong_jwt_secret_key (至少64位随机字符串)
JWT_EXPIRES_IN=7d

# 服务器配置
PORT=3002
NODE_ENV=production

# 文件上传配置
UPLOAD_PATH=../uploads
MAX_FILE_SIZE=5242880

# 前端地址
CLIENT_URL=https://your-domain.com

# 邮箱配置 (网易163)
EMAIL_HOST=smtp.163.com
EMAIL_PORT=465
EMAIL_USER=your-email@163.com
EMAIL_PASS=your_email_app_password

# 邮箱配置 (QQ邮箱)
EMAIL_QQ_HOST=smtp.qq.com
EMAIL_QQ_PORT=465
EMAIL_QQ_USER=your-email@qq.com
EMAIL_QQ_PASS=your_qq_email_app_password
